# =============================================================================
# FDA Data Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments and are ignored.
# =============================================================================

# --- API Configuration ---

# OpenFDA API base URL (default shown; change only if endpoint changes)
# FDA_API_BASE_URL=https://api.fda.gov/drug/drugsfda.json

# Optional API key for higher rate limits.
# Register at: https://open.fda.gov/apis/authentication/
# Leave blank to use the public (lower) rate limit.
FDA_API_KEY=

# Records per API request (max 1000, which is the OpenFDA hard limit)
# FDA_API_PAGE_SIZE=1000

# Retry settings for transient API failures
# FDA_API_MAX_RETRIES=3
# FDA_API_RETRY_BACKOFF_BASE=2.0

# --- Storage Configuration ---

# Storage backend: "local" (writes CSV to local disk) or "cloud" (S3/GCS)
STORAGE_BACKEND=local

# Local storage: directory for output files (relative or absolute path)
# DATA_DIR=./fda_data

# Cloud storage (only used when STORAGE_BACKEND=cloud):
# CLOUD_STORAGE_PROVIDER=gcs         # "gcs" for Google Cloud Storage
# CLOUD_STORAGE_BUCKET=my-bucket     # Your GCS bucket name
# CLOUD_STORAGE_PREFIX=fda_data/     # Key prefix inside the bucket
#
# GCP authentication: on Cloud Run this is automatic via the service account.
# For local testing against GCS, run: gcloud auth application-default login

# --- Scheduler Configuration ---

# Scheduler backend:
#   "local"  — in-process schedule loop (for local/Docker use)
#   "cloud"  — no-op; GCP Cloud Scheduler calls POST /api/run externally
SCHEDULER_BACKEND=local

# Time to run the nightly job (HH:MM, 24-hour local time)
SCHEDULE_TIME=02:00

# --- Logging ---

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Path to the log file
# LOG_FILE=./fda_data/pipeline.log
